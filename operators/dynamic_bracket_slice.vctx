component DynBracketSlice(in hi: u4, in lo: u4, in w: u16, out z: u8) {
    z := w[hi..lo]
}

sim DynamicBracketSlice {
    wire hi: u4
    wire lo: u4
    wire wv: u16
    wire z: u8
    poke(hi, 7 as u4)
    poke(lo, 0 as u4)
    poke(wv, 0x1234 as u16)
    DynBracketSlice(hi, lo, wv, z)
    cycle()
    assert(z == 0x34 as u8, "low byte of 0x1234")
}

