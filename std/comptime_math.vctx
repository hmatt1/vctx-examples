// Minimal stdlib-style comptime helpers.
// In the future, this can become `std.math` or similar; for now keep it small and explicit.

comptime clog2(n: Int) -> u32 {
    assert(n > 0, "clog2 domain: n > 0")
    let x: Int = n - 1
    let r: Int = 0
    while (x > 0) {
        x = x / 2
        r = r + 1
    }
    return (r as u32)
}

