// Expected failure: generic functions using parametric carriers should typecheck/specialize.
// Promotion target: move to passing sims once function-level `u<W>` paths are supported.

function id_n<W>(x: u<W>) -> u<W> {
    return x
}

component UseParametricFunction(in a: u8, out y: u8) {
    y := id_n<8>(a)
}

sim ParametricCarrierFunctionShouldWork {
    wire a: u8 = 9
    wire y: u8
    UseParametricFunction(a, y)
    cycle()
    assert(y == 9 as u8, "id_n<8>(9) should return 9")
}

