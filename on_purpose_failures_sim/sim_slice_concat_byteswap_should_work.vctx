// Expected failure: byte swap via slice + concat (16-bit) should match manual concat.
// Promotion: move to passing when slice+concat on concrete carriers matches 0x3412 for 0x1234.

sim SliceConcatByteswapShouldWork {
    wire x: u16 = 0x1234
    wire y: u16
    y := concat(x[7..0], x[15..8])
    cycle()
    assert(y == 0x3412, "byte swap 0x1234 -> 0x3412")
}
