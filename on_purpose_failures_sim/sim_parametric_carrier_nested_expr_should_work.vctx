// Expected failure: nested arithmetic over generic Ints in carrier widths should fold.
// Promotion target: move to passing sims once nested carrier expressions specialize.

component DoubleWidth<W>(in x: u<W>, out y: u<(W + W)>) {
    y := x as u<(W + W)>
}

sim ParametricCarrierNestedExprShouldWork {
    wire x: u4 = 0xA
    wire y: u8
    DoubleWidth<4>(x -- x, y -- y)
    cycle()
    assert(y == 0x0A as u8, "u<(W+W)> with W=4 should produce u8 value")
}

