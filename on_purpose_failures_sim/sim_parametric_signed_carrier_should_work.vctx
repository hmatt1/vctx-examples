// Expected failure: signed parametric carriers s<W> should specialize in sim path.
// Promotion target: move to passing sims once signed carrier generics are supported.

component SignedPass<W>(in x: s<W>, out y: s<W>) {
    y := x
}

sim ParametricSignedCarrierShouldWork {
    wire x: s8 = -5
    wire y: s8
    SignedPass<8>(x -- x, y -- y)
    cycle()
    assert(y == -5 as s8, "SignedPass<8> should preserve signed value")
}

