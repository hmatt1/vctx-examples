// Expected failure: comptime statement evaluator should handle loops + arithmetic.

comptime eval_cov(n: Int) -> u32 {
    let x: Int = n
    let r: Int = 0
    while (x > 0) {
        x = x / 2
        r = r + 1
    }
    return (r as u32)
}

component ComptimeEvalCoverage(out w: u32) {
    w := eval_cov(16)
}

sim ComptimeEvalCovShouldWork {
    wire w: u32
    ComptimeEvalCoverage(w)
    cycle()
    assert(w == 5 as u32, "eval_cov(16) == 5")
}

