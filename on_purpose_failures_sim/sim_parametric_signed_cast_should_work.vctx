// Expected failure: casts between parametric signed/unsigned carriers should specialize.
// Promotion target: move to passing sims once signed/unsigned generic cast paths are stable.

component ParametricSignedCast<W>(in x: s<W>, out y: u<W>) {
    y := x as u<W>
}

sim ParametricSignedCastShouldWork {
    wire x: s8 = -1
    wire y: u8
    ParametricSignedCast<8>(x -- x, y -- y)
    cycle()
    assert(y == 0xFF as u8, "casting -1 as u8 should yield 0xFF")
}

