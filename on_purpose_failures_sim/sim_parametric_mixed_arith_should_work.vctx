// Expected failure: mixed arithmetic over parametric widths should fold/specialize.
// Promotion target: move to passing sims when generic arithmetic widths are supported.

component MixedArith<W>(in x: u<W>, in y: u<W>, out z: u<(W + 1)>) {
    z := (x + y) as u<(W + 1)>
}

sim ParametricMixedArithShouldWork {
    wire x: u8 = 100
    wire y: u8 = 27
    wire z: u9
    MixedArith<8>(x -- x, y -- y, z -- z)
    cycle()
    assert(z == 127 as u9, "MixedArith<8>(100,27) should be 127 in u9")
}

