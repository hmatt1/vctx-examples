comptime loop_control() -> u32 {
    let i: Int = 0
    let s: Int = 0
    while (true) {
        i = i + 1
        if (i == 2) {
            continue
        }
        if (i == 4) {
            break
        }
        s = s + i
    }
    return (s as u32)
}

component ComptimeLoopControl(out w: u32) {
    w := loop_control()
}

sim SimComptimeLoopControl {
    wire w: u32
    ComptimeLoopControl(w)
    cycle()
    assert(w == 4 as u32, "break/continue")
}

