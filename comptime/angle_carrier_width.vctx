// Smoke: parameterized carrier types u<…> / s<…> (grammar + type IR).

component AngleWidthDemo(
    in a: u<4 + 4>,
    in b: s<8>,
    out y: u<8>
) {
    y := (((a as u8) + (b as u8)) as u8)
}

function int_id(n: Int) -> Int {
    return n
}

sim SimAngleWidthSmoke {
    wire av: u8 = 1
    wire bv: s8 = 2
    wire yv: u8
    AngleWidthDemo(av, bv, yv)
    cycle()
    assert(yv == 3 as u8, "1+2")
}
